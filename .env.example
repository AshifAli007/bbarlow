# Cloudinary — used to host & transform Beth's race photos.
# Create a free account at https://cloudinary.com, then copy these from your
# dashboard (Settings -> API Keys). Save your real values in a `.env` file
# (which is gitignored). The upload script reads the secret values; the site
# only needs the public cloud name.

# Public — safe to expose in the browser (used to build image URLs).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Private — server/script only. NEVER commit these.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Absolute path to the folder of original photos to upload.
# Defaults to the user's "Beth FSU" Pictures folder if unset.
PHOTOS_DIR=/Users/ashif/Pictures/Beth FSU
